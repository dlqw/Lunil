<Project>
  <PropertyGroup>
    <_LunilBuildTaskAssembly Condition="'$(_LunilBuildTaskAssembly)' == ''">$(MSBuildThisFileDirectory)..\tasks\net10.0\Lunil.Build.dll</_LunilBuildTaskAssembly>
    <_LunilIntermediateOutputPath>$(LunilIntermediateOutputPath)$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\</_LunilIntermediateOutputPath>
    <_LunilTaskOutputPath Condition="'$(DesignTimeBuild)' == 'true'">$(_LunilIntermediateOutputPath)designtime\</_LunilTaskOutputPath>
    <_LunilTaskOutputPath Condition="'$(_LunilTaskOutputPath)' == ''">$(_LunilIntermediateOutputPath)</_LunilTaskOutputPath>
  </PropertyGroup>

  <UsingTask TaskName="Lunil.Build.Tasks.LunilCompileTask" AssemblyFile="$(_LunilBuildTaskAssembly)" />

  <Target Name="LunilCompileModules"
          BeforeTargets="ResolveAssemblyReferences"
          Condition="'$(LunilBuildEnabled)' == 'true' and '@(LunilCompile)' != ''">
    <MakeDir Directories="$(_LunilTaskOutputPath)" />
    <LunilCompileTask Sources="@(LunilCompile)"
                      IntermediateOutputPath="$(_LunilTaskOutputPath)"
                      ProjectDirectory="$(MSBuildProjectDirectory)"
                      TargetFramework="$(TargetFramework)"
                      RuntimeIdentifier="$(RuntimeIdentifier)"
                      DesignTimeBuild="$(DesignTimeBuild)"
                      CacheEnabled="$(LunilCacheEnabled)"
                      CacheDirectory="$(LunilCacheDirectory)"
                      CacheMaximumBytes="$(LunilCacheMaximumBytes)"
                      CacheMaximumEntryBytes="$(LunilCacheMaximumEntryBytes)"
                      CacheMaximumQuarantineBytes="$(LunilCacheMaximumQuarantineBytes)"
                      PublishAot="$(PublishAot)"
                      PublishReadyToRun="$(PublishReadyToRun)"
                      PublishTrimmed="$(PublishTrimmed)">
      <Output TaskParameter="GeneratedSources" ItemName="Compile" />
      <Output TaskParameter="GeneratedReferences" ItemName="Reference" />
      <Output TaskParameter="GeneratedArtifacts" ItemName="FileWrites" />
    </LunilCompileTask>
  </Target>

  <Target Name="LunilClean" BeforeTargets="CoreClean" Condition="Exists('$(LunilIntermediateOutputPath)')">
    <RemoveDir Directories="$(LunilIntermediateOutputPath)" />
  </Target>
</Project>
