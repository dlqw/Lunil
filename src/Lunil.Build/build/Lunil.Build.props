<Project>
  <PropertyGroup>
    <LunilBuildEnabled Condition="'$(LunilBuildEnabled)' == ''">true</LunilBuildEnabled>
    <LunilIntermediateOutputPath Condition="'$(LunilIntermediateOutputPath)' == ''">$(BaseIntermediateOutputPath)lunil\</LunilIntermediateOutputPath>
    <LunilOptimization Condition="'$(LunilOptimization)' == '' and '$(Optimize)' == 'true'">Release</LunilOptimization>
    <LunilOptimization Condition="'$(LunilOptimization)' == ''">Debug</LunilOptimization>
    <LunilDebugSymbols Condition="'$(LunilDebugSymbols)' == '' and '$(DebugSymbols)' == 'true'">true</LunilDebugSymbols>
    <LunilDebugSymbols Condition="'$(LunilDebugSymbols)' == ''">false</LunilDebugSymbols>
    <LunilSandbox Condition="'$(LunilSandbox)' == ''">Default</LunilSandbox>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <LunilCompile>
      <ModuleName>%(Filename)</ModuleName>
      <InputKind>Auto</InputKind>
      <Optimization>$(LunilOptimization)</Optimization>
      <DebugSymbols>$(LunilDebugSymbols)</DebugSymbols>
      <Sandbox>$(LunilSandbox)</Sandbox>
    </LunilCompile>
  </ItemDefinitionGroup>
</Project>
